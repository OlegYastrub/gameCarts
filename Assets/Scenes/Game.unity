    \u0431\u044B \n\u0412\u044B \u043F\u0435\u0440\u0432\u044B\u043C \u0445\u043E\u0434\u043E\u043C
    \u0441\u044B\u0433\u0440\u0430\u043B\u0438 \"10-\u043A\u043E\u0439\",\n\u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u043C
    \u0445\u043E\u0434\u043E\u043C \u0441\u044B\u0433\u0440\u0430\u043B\u0438 \"7-\u043A\u043E\u0439\",\n\u0448\u0435\u0441\u0442\u044B\u043C
    \u0445\u043E\u0434\u043E\u043C \u0441\u044B\u0433\u0440\u0430\u043B\u0438 \"\u041A\u043E\u0440\u043E\u043B\u0435\u043C\",\n\u0430
    \u0432\u043E\u0441\u044C\u043C\u044B\u043C \u0445\u043E\u0434\u043E\u043C \u0441\u044B\u0433\u0440\u0430\u043B\u0438
    \"\u0414\u0430\u043C\u043E\u0439\"!"
